# Clerk JWT validation (required)
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts
# Optional if issuer is set, but you can set directly
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts/.well-known/jwks.json
# Optional, only needed if your JWTs include an audience claim
CLERK_AUDIENCE=

# API server settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (placeholder, not wired yet)
DATABASE_URL=sqlite:///./vulture.db

# GitHub OAuth (token is read from Clerk private metadata)
GITHUB_APP_NAME=vulture

# AWS Bedrock (placeholder, not wired yet)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Scan settings
MAX_REPO_SIZE_MB=500
SCAN_TMP_DIR=/tmp/vulture_scans
