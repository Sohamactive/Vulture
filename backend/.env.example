# Clerk JWT validation (required)
CLERK_ISSUER=
# Optional if issuer is set, but you can set directly
CLERK_JWKS_URL=
# Optional, only needed if your JWTs include an audience claim
CLERK_AUDIENCE=

# API server settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (placeholder, not wired yet)
DATABASE_URL=sqlite:///./vulture.db

# GitHub OAuth (token is read from Clerk private metadata)
GITHUB_APP_NAME=vulture

# AWS Bedrock (placeholder, not wired yet)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEDROCK_MODEL_ID=mistral.mistral-large-3-675b-instruct
AWS_BEARER_TOKEN_BEDROCK=
OPENAI_API_KEY=
OPENAI_BASE_URL="https://bedrock-mantle.ap-south-1.api.aws/v1"
# Scan settings
MAX_REPO_SIZE_MB=500
SCAN_TMP_DIR=/tmp/vulture_scans


GEMINI_API_KEY=
GEMINI_MODEL_ID=gemma-4-31b-it